# --------------------------------------------------------
# --- GENERIC STARTUP CONTROL VARIABLES ------------------
# --- Config file rename map ---
# Comma-separated "source.yml.example:target.yml" overrides.
# Any *.yml.example not listed is copied to *.yml (strips .example).
CONFIG_RENAMES=emr_migration.yml.example:openmrs_migration.yml

# --- Number of connection attempt before failure
MYSQL_CONN_FAIL=5

# --- Database setup failure behaviour ---
# Set to true to terminate the container if db:create, db:migrate or db:seed fails.
DB_FAIL_EXIT=true

# --------------------------------------------------------
# --- RAILS SERVER ---------------------------------------
BIND_IP=0.0.0.0
BIND_PORT=3000
RAILS_ENV=production
RAILS_LOG_TO_STDOUT=true
DDE_HOST_URL=http://localhost:3000
REDIS_URL=redis://localhost:6379/2
RAILS_SERVE_STATIC_FILES=true

# --------------------------------------------------------
# --- DATABASE.YML ---------------------------------------
# default
RAILS_MAX_THREADS=5
DB_USERNAME="root"
DB_PASSWORD="root_password"
DB_NAME="dde"
DB_HOST="sis-h-db"
DB_PORT=3306
DB_IDLE_TIMEOUT=1

# batch_size
BATCH_SIZE=10_000

# dde_sync_config
DDE_SYNC_PROTOCOL="https"
DDE_SYNC_HOST="ddedashboard.example.com"
DDE_SYNC_USER="test"
DDE_SYNC_PASS="test"

# email_config
EMAIL_USER="example@gmail.com"
EMAIL_PASS="password"
EMAIL_ADDRESS="smtp.gmail.com"
EMAIL_PORT=587
EMAIL_AUTH_METHOD="login"
EMAIL_STARTTLS=true


# --------------------------------------------------------
# --- EMR_MIGRATION.YML ----------------------------------
# # MySQL EMR Database - emr_database:
EMR_DB_HOST="localhost"
EMR_DB_PORT=3306
EMR_DB_USER="root"
EMR_DB_PASS="YOUR_OPENMRS_PASSWORD"
EMR_DB_NAME="openmrs"

# Proxy Server (DDE) - proxy:
PROXY_PROTOCOL="http"
PROXY_HOST="127.0.0.1"
PROXY_PORT=8050
PROXY_USER="YOUR_PROXY_USERNAME"
PROXY_PASS="YOUR_PROXY_PASSWORD"

# Migration Settings - migration:
MIGRATION_BATCH_SIZE=100
MIGRATION_MAX_RETRIES=3
MIGRATION_RETRY_DELAY=2
HTTP_OPEN_TIMEOUT=10
HTTP_READ_TIMEOUT=30

# Write-Back Settings (NPID → EMR) - writeback:
WRITEBACK_LOCATION_ID=319
NPID_IDENTIFIER_TYPE=3
DOC_ID_IDENTIFIER_TYPE=18
WRITEBACK_BATCH_SIZE=500

# --------------------------------------------------------
# --- MASTER_COUCHDB.YML ---------------------------------
MASTER_COUCH_DB_PROTOCOL="http"
MASTER_COUCH_DB_HOST="localhost"
MASTER_COUCH_DB_PORT=5984
MASTER_COUCH_DB_USER="root"
MASTER_COUCH_DB_PASS="root"
MASTER_COUCH_DB_NAME="dde3_master_production"
MASTER_COUCH_DB_BIDIRECTIONAL=true

# --------------------------------------------------------
# --- SECRETS.YML ----------------------------------------
SECRET_KEY_BASE=changeme_run_rails_secret_to_generate

# --------------------------------------------------------
# --- SETTINGS.YML ----------------------------------------
SETTINGS_SECRET_KEY=""
SETTINGS_DUPLICATE_PRECISION=90
SETTINGS_GATEWAY_KEY="usermanagement"
SETTINGS_SSS_URL="localhost:3001"

# --------------------------------------------------------
# --- SIDEKIQ.YML ----------------------------------------
SIDEKIQ_CONCURRENCY=4
SIDEKIQ_REDIS_URL=redis://localhost:6379/0

# --------------------------------------------------------
# --- SMTP_SETTINGS.YML ----------------------------------
SMTP_SERVER=localhost
SMTP_SERVER_PORT=587
SMTP_ADDRESS=test@test.com
SMTP_PASSWORD=password
SMTP_AUTHENTICATION=login
SMTP_STARTTLS_AUTO=true
SMTP_DOMAIN="example.com"
# --------------------------------------------------------
