# EMR Bulk Migration Configuration
# ============================================================================
# Copia este ficheiro para openmrs_migration.yml e preenche com as
# credenciais do teu ambiente:
#
#   cp config/openmrs_migration.yml.example config/openmrs_migration.yml
# ============================================================================

# MySQL EMR Database
emr_database:
  host: <%= ENV.fetch("EMR_DB_HOST", "localhost") %>
  port: <%= ENV.fetch("EMR_DB_PORT", 3306) %>
  username: <%= ENV.fetch("EMR_DB_USER", "root") %>
  password: <%= ENV.fetch("EMR_DB_PASS", "YOUR_OPENMRS_PASSWORD") %>
  database: <%= ENV.fetch("EMR_DB_NAME", "openmrs") %>

# Proxy Server (DDE)
proxy:
  protocol: <%= ENV.fetch("PROXY_PROTOCOL", "http") %>
  host: <%= ENV.fetch("PROXY_HOST", "127.0.0.1") %>
  port: <%= ENV.fetch("PROXY_PORT", 8050) %>
  username: <%= ENV.fetch("PROXY_USER", "YOUR_PROXY_USERNAME") %>
  password: <%= ENV.fetch("PROXY_PASS", "YOUR_PROXY_PASSWORD") %>

# Migration Settings
migration:
  batch_size: <%= ENV.fetch("MIGRATION_BATCH_SIZE", 100) %>        # Número de pacientes por página (leitura do DB)
  max_retries: <%= ENV.fetch("MIGRATION_MAX_RETRIES", 3) %>        # Tentativas em caso de falha de rede
  retry_delay: <%= ENV.fetch("MIGRATION_RETRY_DELAY", 2) %>        # Base do backoff exponencial (segundos)
  http_open_timeout: <%= ENV.fetch("HTTP_OPEN_TIMEOUT", 10) %>     # Timeout de conexão HTTP (segundos)
  http_read_timeout: <%= ENV.fetch("HTTP_READ_TIMEOUT", 30) %>     # Timeout de leitura HTTP (segundos)

# Write-Back Settings (NPID → EMR)
writeback:
  location_id: <%= ENV.fetch("WRITEBACK_LOCATION_ID", 319) %>                # ID da localização no OpenMRS/SIS-RME
  npid_identifier_type: <%= ENV.fetch("NPID_IDENTIFIER_TYPE", 3) %>          # patient_identifier_type.patient_identifier_type_id para NPID
  doc_id_identifier_type: <%= ENV.fetch("DOC_ID_IDENTIFIER_TYPE", 18) %>     # patient_identifier_type.patient_identifier_type_id para doc_id (UUID do proxy)
  batch_size: <%= ENV.fetch("WRITEBACK_BATCH_SIZE", 500) %>                  # Número de registos por batch de inserção
